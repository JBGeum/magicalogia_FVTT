{{!--
  마기카로기아 Actor Sheet — main template (layout C / dashboard)
  Root <form> gets ".magicalogia .sheet .actor" from defaultOptions.classes;
  the theme class (.theme-dark / .theme-light) is added in _render().
  Data paths shown (system.*) are an EXAMPLE model — align with your template.json.
--}}
<form class="{{cssClass}}" autocomplete="off">
  <div class="mg-content">

    {{!-- ===== Masthead ===== --}}
    <header class="mg-masthead">
      <div>
        <div class="mg-masthead__eyebrow">❧ 파토서대전 RPG ❧</div>
        <span class="mg-masthead__title">마기카로기아</span>
        <span class="mg-masthead__latin">CHARACTER SHEET</span>
      </div>
      <div class="mg-masthead__sigil">✶</div>
    </header>

    {{!-- ===== Tabs ===== --}}
    <nav class="mg-tabs" data-group="primary">
      <a class="mg-tab" data-tab="main">캐릭터 시트</a>
      <a class="mg-tab" data-tab="grimoire">장서</a>
      <a class="mg-tab" data-tab="relations">관계</a>
      <a class="mg-tab is-disabled" title="준비 중">개요·정보</a>
      <a class="mg-tab is-disabled" title="준비 중">속성·능력</a>
    </nav>

    <section class="mg-tab-content">

      {{!-- ============ TAB: 캐릭터 시트 ============ --}}
      <div class="tab mg-main" data-tab="main">

        {{!-- C : dashboard header band --}}
        <div class="mg-headband">

          {{!-- portrait (click to edit image in Foundry) --}}
          <div class="mg-portrait" data-edit="img">
            {{#if actor.img}}<img src="{{actor.img}}" alt="portrait">{{else}}
              <span class="mg-corner mg-corner--tl"></span><span class="mg-corner mg-corner--tr"></span>
              <span class="mg-corner mg-corner--bl"></span><span class="mg-corner mg-corner--br"></span>
              <span class="mg-portrait__glyph">✶</span><span class="mg-portrait__hint">초상화</span>
            {{/if}}
          </div>

          {{!-- identity (2-col) --}}
          <div class="mg-identity-grid">
            {{> mg-field mark="❖" label="임시 이름"  name="system.tempName"      value=system.tempName}}
            {{> mg-field mark="❖" label="경력"       name="system.career"        value=system.career}}
            {{> mg-field mark="❖" label="마법명"     name="system.magicName"     value=system.magicName}}
            {{> mg-field mark="❖" label="기관"       name="system.organization"  value=system.organization}}
            {{> mg-field mark="❖" label="플레이어"   name="system.player"        value=system.player}}
            {{> mg-field mark="❖" label="신분"       name="system.socialStatus"  value=system.socialStatus}}
            {{> mg-field mark="❖" label="성별·연령"  name="system.genderAge"     value=system.genderAge}}
            {{> mg-field mark="❖" label="진정한 모습" name="system.trueForm"     value=system.trueForm}}
            <label class="mg-field mg-field--wide mg-field--effect">
              <span class="mg-field__mark">❖</span>
              <span class="mg-field__label">효과</span>
              <input class="mg-field__value" type="text" name="system.effect" value="{{system.effect}}" placeholder="—">
              <span class="mg-field__dots"><span class="mg-dot"></span><span class="mg-dot"></span></span>
            </label>
          </div>

          {{!-- stat rail --}}
          <div class="mg-statrail">
            <div class="mg-stat-row">
              <label class="mg-stat"><span class="mg-stat__label">공격</span><input class="mg-stat__value" name="system.attack"  value="{{system.attack}}"></label>
              <label class="mg-stat"><span class="mg-stat__label">방어</span><input class="mg-stat__value" name="system.defense" value="{{system.defense}}"></label>
              <label class="mg-stat"><span class="mg-stat__label">근원</span><input class="mg-stat__value" name="system.source"  value="{{system.source}}"></label>
            </div>
            <div class="mg-gauge">
              <span class="mg-gauge__icon">◈</span><span class="mg-gauge__label">마력</span>
              <input class="mg-gauge__value" name="system.mana.value" value="{{system.mana.value}}">
              <span class="mg-gauge__sep">/</span>
              <input class="mg-gauge__max" name="system.mana.max" value="{{system.mana.max}}">
            </div>
            <div class="mg-gauge">
              <span class="mg-gauge__icon">◇</span><span class="mg-gauge__label">일시 마력</span>
              <input class="mg-gauge__value" name="system.tempMana" value="{{system.tempMana}}">
            </div>
            <div class="mg-counter-row">
              <label class="mg-counter"><span class="mg-counter__label">공적점</span><input class="mg-counter__value" name="system.achievement" value="{{system.achievement}}"></label>
              <label class="mg-counter"><span class="mg-counter__label">마화</span><input class="mg-counter__value" name="system.maHwa" value="{{system.maHwa}}"></label>
            </div>
          </div>
        </div>

        {{!-- status-ailment strip --}}
        <div class="mg-status">
          <span class="mg-status__title"><span class="mark">❖</span>상태이상</span>
          <span class="mg-status__list">
            {{#each statuses}}<span class="mg-status__chip {{#if this.active}}is-active{{/if}}" data-status="{{this.key}}">{{this.label}}</span>{{/each}}
          </span>
        </div>

        {{!-- sub-tabs + magic chart + memo/tables --}}
        <div class="mg-shared">
          <div class="mg-subtabs">
            <a class="mg-subtab is-active">특기</a>
            <a class="mg-subtab">설정</a>
          </div>

          {{> mg-magic-chart}}

          <div class="mg-belowgrid">
            <div class="mg-memo">
              <span class="mg-memo__label">메 모</span>
              <textarea name="system.memo">{{system.memo}}</textarea>
            </div>
            <div>
              <div class="mg-banner mg-banner--inline" style="margin-bottom:6px">
                <span class="mg-banner__rule mg-banner__rule--l"></span>
                <span class="mg-banner__label">주사위 및 각종 표</span>
                <span class="mg-banner__rule mg-banner__rule--r"></span>
              </div>
              <div class="mg-tables">
                <div class="mg-tablecard"><div class="mg-tablecard__head">가변특기</div><div class="mg-tablecard__body mg-tablecard__body--select">{{system.variableSkill}}<span class="caret">▾</span></div></div>
                <div class="mg-tablecard"><div class="mg-tablecard__head">운명 변전</div><div class="mg-tablecard__body mg-tablecard__body--btn" data-action="roll-fate">⚙</div></div>
                <div class="mg-tablecard"><div class="mg-tablecard__head">장면 표</div><div class="mg-tablecard__body mg-tablecard__body--btn" data-action="roll-scene">⚙</div></div>
                <div class="mg-tablecard"><div class="mg-tablecard__head">주사위</div><div class="mg-tablecard__body mg-tablecard__body--roll">{{#if system.dice}}{{system.dice}}{{else}}D6{{/if}}</div></div>
                <div class="mg-tablecard"><div class="mg-tablecard__head">펌블 표</div><div class="mg-tablecard__body mg-tablecard__body--btn" data-action="roll-fumble">⚙</div></div>
                <div class="mg-tablecard"><div class="mg-tablecard__head">사건 표</div><div class="mg-tablecard__body mg-tablecard__body--btn" data-action="roll-event">⚙</div></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {{!-- ============ TAB: 장서 ============ --}}
      <div class="tab mg-panel-body--pad" data-tab="grimoire" style="display:flex;flex-direction:column;gap:12px">
        <div class="mg-banner">
          <span class="mg-banner__rule mg-banner__rule--l"></span><span class="mg-banner__label">장 서</span><span class="mg-banner__rule mg-banner__rule--r"></span>
        </div>
        {{> mg-grimoire}}
      </div>

      {{!-- ============ TAB: 관계 ============ --}}
      <div class="tab mg-panel-body--pad" data-tab="relations" style="display:flex;flex-direction:column;gap:12px">
        <div class="mg-banner">
          <span class="mg-banner__rule mg-banner__rule--l"></span><span class="mg-banner__label">관 계</span><span class="mg-banner__rule mg-banner__rule--r"></span>
        </div>
        {{> mg-relations}}
      </div>

    </section>
  </div>
</form>
