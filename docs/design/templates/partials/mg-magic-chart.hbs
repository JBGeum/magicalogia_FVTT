{{!-- partial: mg-magic-chart — 마법표 (output of getData → ctx.chart / ctx.chartIndex) --}}
<div class="mg-chart">
  <div class="mg-chart__grid">

    {{!-- 출목 (2–12) --}}
    <div class="mg-chart__index">
      <div class="mg-chart__head"><span class="num">치</span></div>
      {{#each chartIndex}}<div class="mg-chart__index-cell">{{this}}</div>{{/each}}
    </div>

    {{!-- attribute columns --}}
    {{#each chart}}
    <div class="mg-chart__col {{#if this.dark}}mg-chart__col--dark{{/if}}">
      <div class="mg-chart__head">
        <span class="mg-check {{#if this.active}}is-on{{/if}}" data-attr="{{this.key}}">{{#if this.active}}✓{{/if}}</span>
        <span class="num">{{this.num}}</span>
        <span class="title">{{this.title}}</span>
      </div>
      {{#each this.rows}}
      <div class="mg-chart__cell {{#if this.on}}is-on{{/if}}" data-skill="{{../key}}.{{this.value}}">
        <span class="mg-check {{#if this.on}}is-on{{/if}}">{{#if this.on}}✓{{/if}}</span>
        <span class="name">{{this.name}}</span>
        <span class="cost">{{this.cost}}</span>
      </div>
      {{/each}}
    </div>
    {{/each}}
  </div>

  {{!-- footer --}}
  <div class="mg-chart__footer">
    <span class="label"><span class="mark">❖</span>혼의 특기 <span class="value">{{system.soulSkill}}</span></span>
    <span class="region"><span style="font-size:12px;color:var(--mg-soft)">영역</span><span class="name">{{system.region}}</span><span class="caret">▾</span></span>
  </div>
</div>
