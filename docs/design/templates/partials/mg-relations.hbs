{{!-- partial: mg-relations — 관계 (anchors). ctx.anchors = array --}}
<div class="mg-table mg-table--relations">
  <div class="mg-table__head">
    <span>□</span><span class="col-name">앵커 이름</span><span>운명</span><span>속성</span><span>✦</span>
  </div>
  {{#each anchors}}
  <div class="mg-table__row">
    <span class="col-check"><span class="mg-check {{#if this.checked}}is-on{{/if}}"></span></span>
    <span class="col-name {{#unless this.name}}col-empty{{/unless}}"><input type="text" name="system.anchors.{{@index}}.name" value="{{this.name}}" placeholder="—"></span>
    <span><input type="text" name="system.anchors.{{@index}}.fate" value="{{this.fate}}"></span>
    <span><input type="text" name="system.anchors.{{@index}}.attr" value="{{this.attr}}"></span>
    <span class="col-check"><span class="mg-check {{#if this.checked}}is-on{{/if}}"></span></span>
  </div>
  {{/each}}
  <div class="mg-table__add" data-action="add-anchor">＋</div>
</div>

<div style="display:flex;flex-direction:column;gap:7px;max-width:440px">
  {{> mg-field mark="❖" label="사명"      name="system.mission"    value=system.mission}}
  {{> mg-field mark="❖" label="수집 장서"  name="system.collection" value=system.collection}}
</div>
