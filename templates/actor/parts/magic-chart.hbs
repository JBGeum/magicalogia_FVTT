<div class="mg-chart">
  <img class="mg-chart__wm" src="systems/magicalogia/assets/chart-watermark.png" alt="" />
  <div class="mg-chart__grid">
    {{!-- 출목 열 --}}
    <div class="mg-chart__index">
      <div class="mg-chart__head"></div>
      {{#each chartRows}}<div class="mg-chart__index-cell">{{this}}</div>{{/each}}
    </div>

    {{!-- 속성 열 (모두 동등) — 열 사이마다 빈 색 띠(gap) 컬럼 삽입 --}}
    {{#each chart}}
    {{#unless @first}}<div class="mg-chart__gap"></div>{{/unless}}
    <div class="mg-chart__col{{#if (eq this.key ../system.domain)}} is-domain{{/if}}">
      <div class="mg-chart__head">
        <span class="ico">{{> "systems/magicalogia/templates/actor/parts/mg-svg-chart-icon.hbs" key=this.key}}</span>
        <span class="num">{{this.num}}</span>
        <span class="title">{{this.title}}</span>
      </div>
      {{#each this.cells}}
      <div class="mg-chart__cell {{#if this.owned}}is-on{{/if}}">
        <span class="mg-check {{#if this.misfortune}}is-on{{/if}}" data-action="toggle-misfortune" data-col="{{../key}}" data-index="{{this.index}}">{{#if this.misfortune}}✓{{/if}}</span>
        <span class="name mg-rollable" data-action="rollSpecialty" data-col="{{../key}}" data-index="{{this.index}}">{{this.name}}</span>
        <span class="tn">{{#if this.tn}}{{this.tn}}{{else}}—{{/if}}</span>
      </div>
      {{/each}}
    </div>
    {{/each}}
  </div>

  <div class="mg-chart__footer">
    <label><span class="mg-flourish">{{> "systems/magicalogia/templates/actor/parts/mg-svg-miniflr.hbs"}}</span>소속영역
      <select class="mg-ident-select" name="system.domain">
        <option value="" {{selected (eq system.domain "")}}>—</option>
        {{#each attributes}}
        <option value="{{this.key}}" {{selected (eq ../system.domain this.key)}}>{{this.title}}</option>
        {{/each}}
      </select>
    </label>
    <label><span class="mg-flourish">{{> "systems/magicalogia/templates/actor/parts/mg-svg-miniflr.hbs"}}</span><span class="mg-rollable" data-action="roll-soul" title="2d6 판정 (목표치 6)">혼의 특기</span> <input class="mg-field__value" type="text" name="system.soulSkill" value="{{system.soulSkill}}" /></label>
    <span class="mg-chart__spacer"></span>
    <label class="mg-chart__wrap"><span class="mg-check {{#if system.horizontalWrap}}is-on{{/if}}" data-action="toggle-wrap" title="어둠-별 가로순환">{{#if system.horizontalWrap}}✓{{/if}}</span>순환</label>
    <button type="button" class="mg-chart__lock" data-action="toggle-skill-edit" title="습득 편집 모드 — 켜면 특기명 클릭으로 습득 토글"><i class="fa-solid fa-lock"></i></button>
  </div>
</div>
