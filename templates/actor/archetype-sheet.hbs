<div class="mg-archetype">
  <header class="mg-archetype__head">
    <img class="mg-archetype__img" src="{{actor.img}}" alt="{{actor.name}}" data-action="editImg" data-edit="img" title="초상화 변경" />
    <input type="text" name="name" value="{{actor.name}}" {{#unless editable}}disabled{{/unless}} />
  </header>

  <div class="mg-archetype__stats">
    <label>블록 보유 <span class="mg-archetype__hint">(원형 HP = 캐릭터 임시체력)</span>
      <input type="checkbox" name="system.hasBlock" {{checked system.hasBlock}} {{#unless editable}}disabled{{/unless}} />
    </label>
    {{#if system.hasBlock}}
    <label>블록(HP)
      <input type="number" name="system.health.value" value="{{system.health.value}}" {{#unless editable}}disabled{{/unless}} />
      / <input type="number" name="system.health.max" value="{{system.health.max}}" {{#unless editable}}disabled{{/unless}} />
    </label>
    {{/if}}
    <label>부스트 수 <span class="mg-archetype__hint">(다이스 N개 부스트)</span>
      <input type="number" name="system.boostCount" value="{{system.boostCount}}" {{#unless editable}}disabled{{/unless}} />
    </label>
    <label>속성
      <select name="system.attr" {{#unless editable}}disabled{{/unless}}>
        <option value="" {{#unless system.attr}}selected{{/unless}}>—</option>
        {{#each attributes}}
        <option value="{{this.key}}" {{#if (eq ../system.attr this.key)}}selected{{/if}}>{{this.title}}</option>
        {{/each}}
      </select>
    </label>
    <label>토큰명 템플릿
      <input type="text" name="system.nameTemplate" value="{{system.nameTemplate}}" placeholder="{skill}의 기사" {{#unless editable}}disabled{{/unless}} />
    </label>
  </div>

  <div class="mg-archetype__features">
    <h3>고유 기능</h3>
    {{#if editable}}
    <prose-mirror name="system.features" button="true" editable="{{editable}}" toggled="false" value="{{system.features}}">{{{enrichedFeatures}}}</prose-mirror>
    {{else}}
    {{{enrichedFeatures}}}
    {{/if}}
  </div>
</form>
