<div class="mg-bdd">
  <div class="mg-bdd__label">{{label}}</div>
  {{#if prompt}}<div class="mg-bdd__prompt">{{prompt}}</div>{{/if}}

  {{#if isBoost}}
  <div class="mg-bdd__boost">
    <button type="button" class="mg-bdd__step" data-action="decN">−</button>
    <span class="mg-bdd__n">{{n}}D6</span>
    <button type="button" class="mg-bdd__step" data-action="incN">＋</button>
  </div>
  {{else}}
  {{#if isWitness}}
  <div class="mg-bdd__sides">
    <button type="button" class="mg-bdd__side{{#if (eq side "attack")}} is-on{{/if}}" data-action="setSide" data-side="attack">공격</button>
    <button type="button" class="mg-bdd__side{{#if (eq side "defense")}} is-on{{/if}}" data-action="setSide" data-side="defense">방어</button>
  </div>
  {{/if}}
  <div class="mg-bdd__faces">
    {{#each faces}}
    <button type="button" class="mg-bdd__face" data-action="addDie" data-value="{{this}}" {{#if ../atMax}}{{#unless ../isFocus}}disabled{{/unless}}{{/if}}>{{this}}</button>
    {{/each}}
    {{#if allowFocus}}
    <button type="button" class="mg-bdd__face mg-bdd__face--focus{{#if isFocus}} is-on{{/if}}" data-action="addDie" data-value="0" title="집중 방어">집중</button>
    {{/if}}
  </div>
  {{#if isFocus}}<div class="mg-bdd__focushint">집중 방어 — 상쇄할 눈 최대 2개(그 눈은 전부 상쇄)</div>{{/if}}
  <div class="mg-bdd__chosen">
    {{#each dice}}
    <button type="button" class="mg-bdd__chip" data-action="removeDie" data-index="{{@index}}">{{this}} ✕</button>
    {{else}}
    <span class="mg-bdd__empty">선택한 다이스 없음</span>
    {{/each}}
  </div>
  {{#unless isFocus}}{{#unless isWitness}}<div class="mg-bdd__count">{{count}} / {{max}}</div>{{/unless}}{{/unless}}
  {{/if}}

  {{#if showRandomSubmit}}
  <button type="button" class="mg-bdd__random" data-action="randomSubmit" {{#if randomDisabled}}disabled{{/if}}>랜덤</button>
  {{/if}}
  <button type="button" class="mg-bdd__submit" data-action="submit">확정</button>
</div>
